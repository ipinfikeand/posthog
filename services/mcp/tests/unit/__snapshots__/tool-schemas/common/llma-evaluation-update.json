{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "conditions": {},
        "deleted": {
            "type": "boolean"
        },
        "description": {
            "type": "string"
        },
        "enabled": {
            "type": "boolean"
        },
        "evaluation_config": {},
        "evaluation_type": {
            "description": "* `llm_judge` - LLM as a judge\n* `hog` - Hog",
            "enum": ["llm_judge", "hog"],
            "type": "string"
        },
        "id": {
            "description": "A UUID string identifying this evaluation.",
            "type": "string"
        },
        "model_configuration": {
            "anyOf": [
                {
                    "description": "Nested serializer for model configuration.",
                    "properties": {
                        "model": {
                            "maxLength": 100,
                            "type": "string"
                        },
                        "provider": {
                            "description": "* `openai` - Openai\n* `anthropic` - Anthropic\n* `gemini` - Gemini\n* `openrouter` - Openrouter\n* `fireworks` - Fireworks",
                            "enum": ["openai", "anthropic", "gemini", "openrouter", "fireworks"],
                            "type": "string"
                        },
                        "provider_key_id": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "null"
                                }
                            ]
                        },
                        "provider_key_name": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "null"
                                }
                            ]
                        }
                    },
                    "required": ["provider", "model"],
                    "type": "object"
                },
                {
                    "type": "null"
                }
            ]
        },
        "name": {
            "maxLength": 400,
            "type": "string"
        },
        "output_config": {},
        "output_type": {
            "description": "* `boolean` - Boolean (Pass/Fail)",
            "enum": ["boolean"],
            "type": "string"
        }
    },
    "required": ["id"],
    "type": "object"
}
