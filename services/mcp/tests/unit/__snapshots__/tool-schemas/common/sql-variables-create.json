{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "default_value": {
            "anyOf": [
                {},
                {
                    "type": "null"
                }
            ]
        },
        "name": {
            "maxLength": 400,
            "type": "string"
        },
        "type": {
            "description": "* `String` - String\n* `Number` - Number\n* `Boolean` - Boolean\n* `List` - List\n* `Date` - Date",
            "enum": ["String", "Number", "Boolean", "List", "Date"],
            "type": "string"
        },
        "values": {
            "anyOf": [
                {},
                {
                    "type": "null"
                }
            ]
        }
    },
    "required": ["name", "type"],
    "type": "object"
}
